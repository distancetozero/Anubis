# Anubis Configuration
# Copy this to anubis.yaml and customize

# Local Ollama LLM (primary — free, private, no internet needed)
ollama:
  host: http://localhost:11434
  model: qwen3:14b
  temperature: 0.1
  context_length: 32768
  timeout: 120

# Groq Cloud LLM (fallback — free tier, blazing fast)
# Get your free API key at: https://console.groq.com
# Set via environment variable: export GROQ_API_KEY=gsk_...
groq:
  api_key: ""  # Or set GROQ_API_KEY env var
  base_url: https://api.groq.com/openai/v1
  model: meta-llama/llama-4-scout-17b-16e-instruct
  fallback_model: qwen/qwen3-32b
  temperature: 0.1
  timeout: 60

# LLM Router — tries providers in priority order
llm_router:
  provider_priority:
    - ollama   # Try local first
    - groq     # Fall back to cloud
  max_retries_per_provider: 3
  retry_delay_seconds: 1.0
  circuit_breaker_threshold: 5
  circuit_breaker_reset_seconds: 300

monitoring:
  poll_interval_seconds: 30
  cpu_alert_threshold: 90.0
  memory_alert_threshold: 85.0
  disk_usage_alert_threshold: 90.0
  temp_alert_threshold_celsius: 85.0
  enable_smart_monitoring: true
  enable_event_log_monitoring: true
  enable_watchdog: true
  watchdog_interval_minutes: 5
  hourly_event_scan: true
  daily_health_report: true

database:
  url: sqlite+aiosqlite:///anubis_telemetry.db
  echo: false

api:
  host: 127.0.0.1
  port: 8484
  reload: false

agents:
  orchestrator_mode: supervisor
  max_agent_iterations: 10
  enable_auto_fix: false
  create_restore_points: true
